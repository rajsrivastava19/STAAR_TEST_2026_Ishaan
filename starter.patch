+.wide-button { width: 100%; }
+
+.results-layout { grid-template-columns: 0.9fr 1.1fr; align-items: start; }
+.score-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
+
+.confetti-strip {
+  display: flex;
+  justify-content: center;
+  gap: 12px;
+  font-size: 1.4rem;
+  color: var(--coral);
+}
+
+.review-card.correct { border-color: rgba(47, 140, 99, 0.26); }
+.review-card.incorrect { border-color: rgba(255, 140, 123, 0.26); }
+
+.directions-text { color: #496e96; }
+.error-card { border-color: rgba(255, 140, 123, 0.35); }
+
+@media (max-width: 900px) {
+  .hero-card,
+  .test-layout,
+  .results-layout {
+    grid-template-columns: 1fr;
+  }
+
+  .hero-stats,
+  .score-grid {
+    grid-template-columns: 1fr;
+  }
+
+  .question-top,
+  .question-footer,
+  .review-top,
+  .intro-actions,
+  .year-card-top {
+    flex-direction: column;
+    align-items: flex-start;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .floaty,
+  .math-rocket {
+    animation: none;
+  }
+
+  .year-card:hover,
+  .option-card:hover,
+  .primary-button:hover,
+  .secondary-button:hover,
+  .palette-dot:hover {
+    transform: none;
+  }
+}
