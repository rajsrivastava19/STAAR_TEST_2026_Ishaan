+import { useEffect, useMemo, useState } from 'react';
+import type { AttemptState, ExamBundle, Manifest, ManifestEntry, Question } from './types';
+
+const emptyAttempt: AttemptState = {
+  answers: {},
+  flagged: {},
+  elapsedSeconds: 0,
+  timerEnabled: false
+};
+
+type Screen = 'home' | 'intro' | 'test' | 'results';
+
+function AnimatedMathSky() {
+  const symbols = ['+', '−', '×', '÷', '★', '✓'];
+  return (
+    <div className="math-sky" aria-hidden="true">
+      {symbols.map((symbol, index) => (
+        <span
+          key={`${symbol}-${index}`}
+          className="floaty"
+          style={{
+            left: `${8 + index * 14}%`,
+            animationDelay: `${index * 0.6}s`
+          }}
+        >
+          {symbol}
+        </span>
+      ))}
+    </div>
+  );
+}
+
+function formatTime(seconds: number) {
+  const mins = Math.floor(seconds / 60);
+  const secs = seconds % 60;
+  return `${mins}:${secs.toString().padStart(2, '0')}`;
+}
+
+function normalizeAnswer(value: string) {
+  return value.replace(/,/g, '').trim().toLowerCase();
+}
+
+function scoreQuestion(question: Question, answer: string | undefined) {
+  if (!answer) return false;
+
+  if (question.answerRule.kind === 'single_choice') {
+    return normalizeAnswer(answer) === normalizeAnswer(question.answerRule.correct);
+  }
+
+  return question.answerRule.acceptedValues.some(
+    (accepted) => normalizeAnswer(accepted) === normalizeAnswer(answer)
+  );
+}
+
+function App() {
+  const [screen, setScreen] = useState<Screen>('home');
+  const [manifest, setManifest] = useState<Manifest | null>(null);
+  const [selectedYear, setSelectedYear] = useState<ManifestEntry | null>(null);
+  const [exam, setExam] = useState<ExamBundle | null>(null);
+  const [attempt, setAttempt] = useState<AttemptState>(emptyAttempt);
+  const [questionIndex, setQuestionIndex] = useState(0);
+  const [loading, setLoading] = useState(true);
+  const [error, setError] = useState<string | null>(null);
+
+  useEffect(() => {
+    async function fetchManifest() {
+      try {
+        const response = await fetch('/api/manifest');
+        const json = (await response.json()) as Manifest;
+        setManifest(json);
+      } catch {
+        setError('Could not load the year list.');
+      } finally {
+        setLoading(false);
+      }
+    }
+
+    void fetchManifest();
+  }, []);
+
+  useEffect(() => {
+    if (screen !== 'test' || !attempt.timerEnabled) return;
+
+    const id = window.setInterval(() => {
+      setAttempt((current) => ({ ...current, elapsedSeconds: current.elapsedSeconds + 1 }));
+    }, 1000);
+
+    return () => window.clearInterval(id);
+  }, [screen, attempt.timerEnabled]);
+
+  useEffect(() => {
+    if (!exam) return;
+    localStorage.setItem(`math-staar-ishaan:${exam.id}`, JSON.stringify(attempt));
+  }, [attempt, exam]);
+
+  const currentQuestion = exam?.questions[questionIndex];
+
+  const results = useMemo(() => {
+    if (!exam) return null;
+
+    const correct = exam.questions.filter((question) => scoreQuestion(question, attempt.answers[question.id])).length;
+    const total = exam.questions.length;
+    const percent = Math.round((correct / total) * 100);
+
+    const byCategory = new Map<string, { correct: number; total: number }>();
+    const byReadiness = new Map<string, { correct: number; total: number }>();
+
+    exam.questions.forEach((question) => {
+      const categoryKey = `Category ${question.metadata.reportingCategory}`;
+      const readinessKey = question.metadata.readinessType;
+      const isCorrect = scoreQuestion(question, attempt.answers[question.id]);
+
+      const category = byCategory.get(categoryKey) ?? { correct: 0, total: 0 };
+      category.total += 1;
+      category.correct += isCorrect ? 1 : 0;
+      byCategory.set(categoryKey, category);
+
+      const readiness = byReadiness.get(readinessKey) ?? { correct: 0, total: 0 };
+      readiness.total += 1;
+      readiness.correct += isCorrect ? 1 : 0;
+      byReadiness.set(readinessKey, readiness);
+    });
+
+    return {
+      correct,
+      total,
+      percent,
+      byCategory: Array.from(byCategory.entries()),
+      byReadiness: Array.from(byReadiness.entries())
+    };
+  }, [attempt.answers, exam]);
+
+  async function chooseYear(entry: ManifestEntry) {
+    setSelectedYear(entry);
+    setScreen('intro');
+
+    if (entry.status !== 'playable') return;
+
+    const response = await fetch(`/api/exams/${entry.slug}`);
+    const json = (await response.json()) as ExamBundle;
+    setExam(json);
+
+    const saved = localStorage.getItem(`math-staar-ishaan:${json.id}`);
+    setAttempt(saved ? (JSON.parse(saved) as AttemptState) : emptyAttempt);
+    setQuestionIndex(0);
+  }
+
+  function startExam() {
+    if (!exam) return;
+    setScreen('test');
+  }
+
+  function updateAnswer(questionId: string, value: string) {
+    setAttempt((current) => ({
+      ...current,
+      answers: {
+        ...current.answers,
+        [questionId]: value
+      }
+    }));
+  }
+
+  function toggleFlag(questionId: string) {
+    setAttempt((current) => ({
+      ...current,
+      flagged: {
+        ...current.flagged,
+        [questionId]: !current.flagged[questionId]
+      }
+    }));
+  }
+
+  function submitExam() {
+    if (!exam) return;
+    const unanswered = exam.questions.filter((question) => !attempt.answers[question.id]).length;
+    const ok = unanswered === 0 || window.confirm(`You still have ${unanswered} unanswered question(s). Submit anyway?`);
+    if (ok) setScreen('results');
+  }
+
+  function resetProgress() {
+    if (!exam) return;
+    localStorage.removeItem(`math-staar-ishaan:${exam.id}`);
+    setAttempt(emptyAttempt);
+    setQuestionIndex(0);
+    setScreen('intro');
+  }
+
+  return (
+    <div className="page-shell">
+      <AnimatedMathSky />
+      <header className="site-header">
+        <div className="title-badge">★</div>
+        <div>
+          <p className="eyebrow">Bright practice. Calm confidence.</p>
+          <h1>Math STAAR Test Prep for Ishaan</h1>
+        </div>
+      </header>
+
+      {loading && <main className="card hero-card"><p>Loading the math mission...</p></main>}
+      {error && <main className="card hero-card error-card"><p>{error}</p></main>}
+
+      {!loading && !error && manifest && screen === 'home' && (
+        <main className="home-grid">
+          <section className="card hero-card">
+            <div className="hero-copy">
+              <span className="hero-pill">For a third grader</span>
+              <h2>Pick a year and jump into practice.</h2>
+              <p>
+                Big buttons, friendly colors, gentle motion, and instant explanations make this feel more like a game board than a worksheet.
+              </p>
+              <div className="hero-stats">
+                <div><strong>Focus</strong><span>One question at a time</span></div>
+                <div><strong>Review</strong><span>See why answers are right or wrong</span></div>
+                <div><strong>Confidence</strong><span>Track progress by category</span></div>
+              </div>
+            </div>
+            <div className="hero-graphic" aria-hidden="true">
+              <div className="planet planet-one" />
+              <div className="planet planet-two" />
+              <div className="math-rocket">➕</div>
+            </div>
+          </section>
+
+          <section className="year-grid">
+            {manifest.years.map((entry) => (
+              <button key={entry.slug} className={`card year-card ${entry.status}`} onClick={() => void chooseYear(entry)}>
+                <div className="year-card-top">
+                  <span className="year-label">{entry.label}</span>
+                  <span className={`status-pill ${entry.status}`}>{entry.status === 'playable' ? 'Ready to play' : 'Coming soon'}</span>
+                </div>
+                <p>{entry.description}</p>
+                <div className="year-meta">
+                  <span>{entry.generation === 'classic' ? 'Classic STAAR' : 'Modern STAAR'}</span>
+                  <span>{entry.playableQuestionCount ?? entry.officialQuestionCount} questions</span>
+                </div>
+              </button>
+            ))}
+          </section>
+        </main>
+      )}
+
+      {screen === 'intro' && selectedYear && (
+        <main className="card intro-card">
+          <h2>{selectedYear.label}</h2>
+          <p>{selectedYear.description}</p>
+
+          <div className="intro-facts">
+            <div><strong>Style</strong><span>{selectedYear.generation === 'classic' ? 'Classic STAAR questions' : 'Modern tech-enhanced questions'}</span></div>
+            <div><strong>Official size</strong><span>{selectedYear.officialQuestionCount} questions</span></div>
+            <div><strong>Playable now</strong><span>{selectedYear.playableQuestionCount ?? 0} questions</span></div>
+          </div>
+
+          {selectedYear.status === 'playable' && exam ? (
+            <>
+              <label className="timer-toggle">
+                <input
+                  type="checkbox"
+                  checked={attempt.timerEnabled}
+                  onChange={(event) => setAttempt((current) => ({ ...current, timerEnabled: event.target.checked }))}
+                />
+                Turn on the timer for game mode
+              </label>
+
+              <div className="intro-actions">
+                <button className="primary-button" onClick={startExam}>Start practice</button>
+                <button className="secondary-button" onClick={() => setScreen('home')}>Back to years</button>
+              </div>
+            </>
+          ) : (
+            <div className="intro-actions">
+              <button className="secondary-button" onClick={() => setScreen('home')}>Back to years</button>
+            </div>
+          )}
+        </main>
+      )}
+
+      {screen === 'test' && exam && currentQuestion && (
+        <main className="test-layout">
+          <aside className="card sidebar-card">
+            <div className="timer-bubble">⏱ {formatTime(attempt.elapsedSeconds)}</div>
+            <h3>{exam.displayTitle}</h3>
+            <p>{questionIndex + 1} of {exam.questions.length}</p>
+            <div className="progress-shell"><div className="progress-bar" style={{ width: `${((questionIndex + 1) / exam.questions.length) * 100}%` }} /></div>
+
+            <div className="palette-grid">
+              {exam.questions.map((question, index) => {
+                const answered = Boolean(attempt.answers[question.id]);
+                const flagged = Boolean(attempt.flagged[question.id]);
+                return (
+                  <button
+                    key={question.id}
+                    className={`palette-dot ${index === questionIndex ? 'current' : ''} ${answered ? 'answered' : ''} ${flagged ? 'flagged' : ''}`}
+                    onClick={() => setQuestionIndex(index)}
+                  >
+                    {index + 1}
+                  </button>
+                );
+              })}
+            </div>
+
+            <button className="secondary-button wide-button" onClick={submitExam}>Finish and score</button>
+          </aside>
+
+          <section className="card question-card">
+            <div className="question-top">
+              <div>
+                <span className="hero-pill">Question {currentQuestion.itemNumber}</span>
+                <h2>{currentQuestion.stem}</h2>
+                {currentQuestion.directions && <p className="directions-text">{currentQuestion.directions}</p>}
+              </div>
+              <button className={`flag-button ${attempt.flagged[currentQuestion.id] ? 'active' : ''}`} onClick={() => toggleFlag(currentQuestion.id)}>
+                {attempt.flagged[currentQuestion.id] ? '⭐ Flagged' : '☆ Flag for review'}
+              </button>
+            </div>
+
+            {currentQuestion.itemType === 'multiple_choice' && currentQuestion.options && (
+              <div className="option-stack">
+                {currentQuestion.options.map((option) => {
+                  const selected = attempt.answers[currentQuestion.id] === option.id;
+                  return (
+                    <button
+                      key={option.id}
+                      className={`option-card ${selected ? 'selected' : ''}`}
+                      onClick={() => updateAnswer(currentQuestion.id, option.id)}
+                    >
+                      <span className="option-chip">{option.id}</span>
+                      <span>{option.text}</span>
+                    </button>
+                  );
+                })}
+              </div>
+            )}
+
+            {currentQuestion.itemType === 'griddable_numeric' && (
+              <div className="numeric-wrap">
+                <label htmlFor={currentQuestion.id}>Type your answer</label>
+                <input
+                  id={currentQuestion.id}
+                  className="numeric-input"
+                  inputMode="numeric"
+                  placeholder="Type a number"
+                  value={attempt.answers[currentQuestion.id] ?? ''}
+                  onChange={(event) => updateAnswer(currentQuestion.id, event.target.value)}
+                />
+              </div>
+            )}
+
+            <div className="question-footer">
+              <button className="secondary-button" disabled={questionIndex === 0} onClick={() => setQuestionIndex((current) => current - 1)}>Previous</button>
+              {questionIndex < exam.questions.length - 1 ? (
+                <button className="primary-button" onClick={() => setQuestionIndex((current) => current + 1)}>Next question</button>
+              ) : (
+                <button className="primary-button" onClick={submitExam}>Submit test</button>
+              )}
+            </div>
+          </section>
+        </main>
+      )}
+
+      {screen === 'results' && exam && results && (
+        <main className="results-layout">
+          <section className="card score-card">
+            <div className="confetti-strip" aria-hidden="true">
+              <span>★</span><span>✓</span><span>★</span><span>✓</span><span>★</span>
+            </div>
+            <h2>You did it!</h2>
+            <div className="score-bubble">{results.percent}%</div>
+            <p>{results.correct} correct out of {results.total}</p>
+            <div className="score-grid">
+              {results.byCategory.map(([label, value]) => (
+                <div key={label} className="mini-score-card"><strong>{label}</strong><span>{value.correct}/{value.total}</span></div>
+              ))}
+              {results.byReadiness.map(([label, value]) => (
+                <div key={label} className="mini-score-card"><strong>{label}</strong><span>{value.correct}/{value.total}</span></div>
+              ))}
+            </div>
+            <div className="intro-actions">
+              <button className="primary-button" onClick={() => setScreen('test')}>Back to review board</button>
+              <button className="secondary-button" onClick={resetProgress}>Start over</button>
+            </div>
+          </section>
+
+          <section className="review-stack">
+            {exam.questions.map((question) => {
+              const answer = attempt.answers[question.id];
+              const isCorrect = scoreQuestion(question, answer);
+              const wrongExplanation = answer && question.rationale.incorrectOptionExplanations?.[answer];
+              const correctAnswer = question.answerRule.kind === 'single_choice'
+                ? question.answerRule.correct
+                : question.answerRule.canonicalValue;
+
+              return (
+                <article key={question.id} className={`card review-card ${isCorrect ? 'correct' : 'incorrect'}`}>
+                  <div className="review-top">
+                    <h3>Question {question.itemNumber}</h3>
+                    <span className={`result-pill ${isCorrect ? 'correct' : 'incorrect'}`}>{isCorrect ? 'Correct' : 'Needs another try'}</span>
+                  </div>
+                  <p>{question.stem}</p>
+                  <p><strong>Your answer:</strong> {answer ?? 'No answer'}</p>
+                  <p><strong>Correct answer:</strong> {correctAnswer}</p>
+                  <p><strong>Why it is right:</strong> {question.rationale.correctExplanation}</p>
+                  {!isCorrect && wrongExplanation && <p><strong>Why your choice missed:</strong> {wrongExplanation}</p>}
+                  {question.rationale.remediationTip && <p><strong>Try this next time:</strong> {question.rationale.remediationTip}</p>}
+                </article>
+              );
+            })}
+          </section>
+        </main>
+      )}
+    </div>
+  );
+}
+
+export default App;
+
